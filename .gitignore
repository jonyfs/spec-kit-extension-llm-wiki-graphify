# Spec Kit local state
.specify/extensions/*/local-config.yml

# Bridge audit log (append-only runtime state, regenerated per run)
.specify/bridge-events.jsonl
.specify/bridge-snapshots/

# Worktrees (created by the worktrees extension)
.worktrees/

# Skill evaluation workspaces (regenerable, large)
.claude/skills/*-workspace/

# Session scratch
.remember/now.md

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
*.swp

# Derived graphify artifacts (Constitution Principle XVII) — never committed
graphify-out/

# ...with one deliberate exception. The mixed-provenance fixture is hand-built test
# data, not a build output: the deterministic build emits only EXTRACTED links, so
# without a committed graph carrying INFERRED and AMBIGUOUS the provenance assertion
# would pass against a graph that proves nothing.
!tests/fixtures/graph-build-mixed/graphify-out/
!tests/fixtures/graph-build-mixed/graphify-out/**
